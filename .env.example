# ─────────────────────────────────────────────────────────────────────────────
# OneMEME Launchpad API — Environment Variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Subgraph endpoint (required) ─────────────────────────────────────────────
# The Graph subgraph GraphQL endpoint — primary data source for all on-chain
# data (tokens, trades, holders, migrations, snapshots, vesting, stats).
#
# Studio (development / staging):
#   https://api.studio.thegraph.com/query/<id>/<slug>/version/latest
# Decentralised network (API key embedded in URL):
#   https://gateway.thegraph.com/api/<api-key>/subgraphs/id/<subgraph-id>
# Self-hosted / custom gateway (use SUBGRAPH_API_KEY for auth instead):
#   https://your-graph-node.example.com/subgraphs/name/<name>
SUBGRAPH_URL=

# ── Subgraph API key (optional) ───────────────────────────────────────────────
# When set, sent as "Authorization: Bearer <key>" on every subgraph request.
# Use this for self-hosted Graph nodes or gateways that require Bearer auth.
# For The Graph's decentralised network the key is embedded in SUBGRAPH_URL
# above — leave this empty in that case.
SUBGRAPH_API_KEY=

# ── BSC HTTP RPC endpoint (required) ─────────────────────────────────────────
# Used by the REST API for live on-demand contract reads:
#   • Bonding curve buy/sell quote simulation
#   • Live PancakeSwap pair price for migrated tokens
#   • metaURI fallback read for post-creation setMetaURI() calls
#
# Provider HTTP endpoints:
#   QuickNode : https://<name>.bsc.discover.quiknode.pro/<token>/
#   Ankr      : https://rpc.ankr.com/bsc/<token>
#   NodeReal  : https://bsc-mainnet.nodereal.io/v1/<token>
#   GetBlock  : https://bsc.getblock.io/<token>/mainnet/
#   Public (dev only, rate-limited): https://bsc-dataseed1.binance.org
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# ── Chain ID (optional) ───────────────────────────────────────────────────────
# EVM chain ID used by the RPC client.
# Default: 56 (BSC mainnet). Use 97 for BSC testnet.
CHAIN_ID=56

# ── BondingCurve contract address (required for quotes) ───────────────────────
# Required for the live quote endpoints (/quote/buy, /quote/sell, /quote/price).
# Leave empty to disable quote endpoints with a 503 response.
BONDING_CURVE_ADDRESS=0x0000000000000000000000000000000000000000

# ── PostgreSQL connection string (required) ───────────────────────────────────
# Stores off-chain data that persists independently of the subgraph:
#   • point_event  — points ledger
#   • referral     — referral registrations
#   • chat_message — per-token chat history
#
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local (docker-compose): postgresql://postgres:password@localhost:5432/onememe
# Hosted (Neon, Supabase, etc.): postgresql://user:pass@host:5432/onememe
DATABASE_URL=postgresql://postgres:password@localhost:5432/onememe

# ── Chain slug (optional) ────────────────────────────────────────────────────
# Short name identifying the network in all API routes.
# All endpoints are served under /api/v1/<CHAIN_SLUG>/...
# Default: bsc
CHAIN_SLUG=bsc

# ── REST API server port (optional) ──────────────────────────────────────────
# Port the NestJS REST API listens on.
# Default: 3001
API_PORT=3001

# ── SSL (optional) ────────────────────────────────────────────────────────────
# Paths to TLS certificate and key files for direct HTTPS.
# When omitted the server runs plain HTTP — use this when TLS is terminated
# externally (Cloudflare, nginx, etc.).
SSL_CERT_PATH=
SSL_KEY_PATH=

# ── Pinata IPFS (required for metadata upload) ────────────────────────────────
# Used by POST /api/v1/metadata/upload to pin token images and metadata JSON
# to IPFS so creators can call setMetaURI() on their token contract.
#
# Get your JWT at: https://app.pinata.cloud/keys
# Create an API key with "pinFileToIPFS" and "pinJSONToIPFS" permissions.
PINATA_JWT=

# ── IPFS gateway (optional) ───────────────────────────────────────────────────
# Used to resolve ipfs:// URIs when the subgraph's ipfs.cat() failed at
# index time and the API falls back to fetching metadata directly.
# Also used to build the gatewayUrl in upload responses.
# Default: https://gateway.pinata.cloud/ipfs/
IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ── Better Stack log shipping (optional) ─────────────────────────────────────
# Source token from logs.betterstack.com — ships NestJS logs to Better Stack.
# See BETTERSTACK.md for setup guide.
BETTERSTACK_TOKEN=

# ── Points system (optional) ─────────────────────────────────────────────────
# POINTS_START_BLOCK — only award points for on-chain events at or after this
# block. Useful for running point seasons / campaigns.
# Falls back to START_BLOCK if unset.
POINTS_START_BLOCK=
START_BLOCK=

# ADMIN_SECRET — required to call the internal points export endpoint.
# GET /api/v1/:chain/points/export  (header: X-Admin-Key: <value>)
# Leave empty to disable the export endpoint entirely.
ADMIN_SECRET=
