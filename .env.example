# ─────────────────────────────────────────────────────────────────────────────
# OneMEME Launchpad Indexer — Environment Variables
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────────────────────

# ── BSC WebSocket RPC endpoint (required) ────────────────────────────────────
# Primary transport for the Ponder indexer. Streams new events in real-time
# via eth_subscribe with sub-second latency and zero polling overhead.
# The indexer will refuse to start if this is not set.
#
# Provider WSS endpoints:
#   QuickNode : wss://<name>.bsc.discover.quiknode.pro/<token>/
#   Ankr      : wss://rpc.ankr.com/bsc/ws/<token>
#   NodeReal  : wss://bsc-mainnet.nodereal.io/ws/v1/<token>
#   GetBlock  : wss://bsc.getblock.io/<token>/mainnet/
BSC_WSS_URL=wss://

# ── BSC HTTP RPC endpoint (required) ─────────────────────────────────────────
# Automatic fallback for the indexer when the WSS connection drops or errors.
# Also used by the REST API server for live quote simulation (contract reads).
# The indexer will refuse to start if this is not set.
# An archive-capable node is required for accurate historical sync.
#
# Provider HTTP endpoints:
#   QuickNode : https://<name>.bsc.discover.quiknode.pro/<token>/
#   Ankr      : https://rpc.ankr.com/bsc/<token>
#   NodeReal  : https://bsc-mainnet.nodereal.io/v1/<token>
#   GetBlock  : https://bsc.getblock.io/<token>/mainnet/
#   Public (dev only, rate-limited): https://bsc-dataseed1.binance.org
BSC_RPC_URL=https://bsc-dataseed1.binance.org

# ── LaunchpadFactory contract address (required) ──────────────────────────────
# The deployed address of the OneMEME LaunchpadFactory on BSC mainnet.
FACTORY_ADDRESS=0x0000000000000000000000000000000000000000

# ── Sync start block (optional) ───────────────────────────────────────────────
# Set to the block number in which the factory was deployed to skip indexing
# the entire chain history before the contract existed.
# Leave empty to start from block 0 (much slower for initial sync).
START_BLOCK=

# ── PostgreSQL connection string (required) ───────────────────────────────────
# Ponder uses this database to persist indexed data and enable the GraphQL API.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local (docker-compose): postgresql://postgres:password@localhost:5432/onememe_indexer
# Hosted:                 postgresql://user:pass@your-db-host:5432/onememe_indexer
DATABASE_URL=postgresql://postgres:password@localhost:5432/onememe_indexer

# ── REST API server port (optional) ──────────────────────────────────────────
# Port the Hono REST API listens on (npm run api / npm run api:dev).
# The Ponder GraphQL API always runs on port 42069.
# Default: 3001
API_PORT=3001

# ── Allowed origins for UI-restricted endpoints (optional) ───────────────────
# Comma-separated list of origins permitted to call the discovery, activity,
# and stats endpoints. Requests from unlisted origins are rejected with 403.
#
# Examples:
#   ALLOWED_ORIGINS=https://onememe.io,https://app.onememe.io
#
# In development (NODE_ENV=development), localhost origins are always allowed
# regardless of this setting, so you don't need to list them.
#
# Leave empty to allow all origins (not recommended for production).
ALLOWED_ORIGINS=https://onememe.io

# ── Pinata IPFS (required for metadata upload) ────────────────────────────────
# Used by POST /api/v1/metadata/upload to pin token images and metadata JSON
# to IPFS so creators can call setMetaURI() on their token contract.
#
# Get your JWT at: https://app.pinata.cloud/keys
# Create an API key with "pinFileToIPFS" and "pinJSONToIPFS" permissions.
PINATA_JWT=

# ── IPFS gateway (optional) ───────────────────────────────────────────────────
# Used to resolve ipfs:// URIs in token metadata and to build gatewayUrl in
# upload responses. Defaults to the public gateway.
# Set to your own gateway for faster / private access.
IPFS_GATEWAY=https://ipfs.io/ipfs/

# ── TLS / HTTPS + WSS (optional) ─────────────────────────────────────────────
# When both vars are set the NestJS API starts in HTTPS mode and WebSocket
# connections automatically use WSS. Leave empty for plain HTTP/WS.
#
# Generate a self-signed cert for local dev:
#   openssl req -x509 -newkey rsa:4096 -keyout certs/privkey.pem -out certs/fullchain.pem -days 365 -nodes
SSL_KEY_PATH=
SSL_CERT_PATH=

# ── Ponder telemetry (optional) ───────────────────────────────────────────────
# Set to "1" to disable anonymous usage statistics sent to the Ponder team.
# PONDER_TELEMETRY_DISABLED=1
