{
  "compilerOptions": {
    "target":                  "ES2021",
    "module":                  "commonjs",
    "moduleResolution":        "node",
    "experimentalDecorators":  true,
    "emitDecoratorMetadata":   true,
    "esModuleInterop":         true,
    "strict":                  true,
    "skipLibCheck":            true,
    "resolveJsonModule":       true,
    "outDir":                  "dist/api",
    "sourceMap":               true,
    "baseUrl":                 "."
  },
  "include":  ["src/api", "abis/**/*.ts"],
  "exclude":  ["node_modules", "dist"]
}
