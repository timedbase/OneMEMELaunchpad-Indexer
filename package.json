    "compression": "^1.8.1",
    "dotenv": "^16.4.7",
    "nest-winston": "^1.10.2",
    "ponder": "^0.8.17",
    "postgres": "^3.4.5",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "viem": "^2.21.45",
    "winston": "^3.19.0",
